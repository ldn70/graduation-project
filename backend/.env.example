DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:5173
DRF_THROTTLE_ANON_RATE=120/min
DRF_THROTTLE_USER_RATE=300/min
DRF_THROTTLE_AUTH_REGISTER_RATE=10/min
DRF_THROTTLE_AUTH_LOGIN_RATE=20/min
DRF_THROTTLE_JOBS_SEARCH_RATE=180/min
DRF_THROTTLE_ANALYSIS_RECOMMEND_RATE=120/min
DRF_THROTTLE_ANALYSIS_SKILL_DEMAND_RATE=150/min
DRF_THROTTLE_ANALYSIS_SKILL_MATCH_RATE=120/min
DRF_THROTTLE_ANALYSIS_SALARY_PREDICT_RATE=90/min
DRF_THROTTLE_ANALYSIS_TRENDS_RATE=120/min
DRF_THROTTLE_RESUME_GENERATE_RATE=30/min
DRF_THROTTLE_RESUME_DOWNLOAD_RATE=180/min
DRF_THROTTLE_AUTH_SECURITY_LOGS_RATE=60/min
AUTH_LOGIN_FAIL_LIMIT_USERNAME=5
AUTH_LOGIN_FAIL_LIMIT_IP=20
AUTH_LOGIN_LOCK_SECONDS=600
AUTH_LOGIN_FAILURE_WINDOW_SECONDS=600

# DB_ENGINE=sqlite | mysql
DB_ENGINE=sqlite
DB_NAME=graduation_project
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Optional MongoDB sync for CSV import command
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=graduation_project
MONGO_JOB_TEXTS_COLLECTION=job_texts
MONGO_TIMEOUT_MS=3000

# Optional recommender model artifact location
RECOMMENDER_MODEL_PATH=

# Optional salary model artifact location
SALARY_MODEL_PATH=
