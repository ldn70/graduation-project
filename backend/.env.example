DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:5173

# DB_ENGINE=sqlite | mysql
DB_ENGINE=sqlite
DB_NAME=graduation_project
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Optional MongoDB sync for CSV import command
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=graduation_project
MONGO_JOB_TEXTS_COLLECTION=job_texts
MONGO_TIMEOUT_MS=3000

# Optional recommender model artifact location
RECOMMENDER_MODEL_PATH=

# Optional salary model artifact location
SALARY_MODEL_PATH=
